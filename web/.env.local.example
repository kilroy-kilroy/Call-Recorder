# Neon Postgres
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Vercel Blob
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Deepgram
DEEPGRAM_API_KEY=your-deepgram-api-key

# Upload auth (shared secret with menubar agent)
UPLOAD_API_KEY=generate-a-random-string

# Simple password gate for web UI
APP_PASSWORD=your-password

# Vercel AI Gateway (auto-provisioned via vercel env pull)
# VERCEL_OIDC_TOKEN=auto
